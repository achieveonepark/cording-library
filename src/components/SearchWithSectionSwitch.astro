---
import DefaultSearch from '@astrojs/starlight/components/Search.astro';
import blogConfig from 'virtual:starlight-blog-config';

const { locale, siteTitleHref } = Astro.locals.starlightRoute;

const labelsByLocale = {
	root: {
		sectionSwitch: '문서/블로그 전환',
		docs: '문서',
		blog: '블로그',
	},
	en: {
		sectionSwitch: 'Switch between docs and blog',
		docs: 'Docs',
		blog: 'Blog',
	},
	ja: {
		sectionSwitch: 'ドキュメントとブログの切り替え',
		docs: 'ドキュメント',
		blog: 'ブログ',
	},
};

const activeLocale = locale ?? 'root';
const labels = labelsByLocale[activeLocale] ?? labelsByLocale.root;

const libraryHref = siteTitleHref;
const blogHref = buildSectionHref(activeLocale, blogConfig.prefix);

const currentPath = normalizePath(Astro.url.pathname);
const blogPath = normalizePath(blogHref);
const isBlogActive = currentPath.startsWith(blogPath);

function buildSectionHref(locale, section = '') {
	const localePrefix = locale && locale !== 'root' ? `/${trimSlashes(locale)}` : '';
	const sectionPath = trimSlashes(section);

	if (!sectionPath) {
		return localePrefix || '/';
	}

	return `${localePrefix}/${sectionPath}`;
}

function trimSlashes(value) {
	return value.replace(/^\/+|\/+$/g, '');
}

function normalizePath(value) {
	const withLeadingSlash = value.startsWith('/') ? value : `/${value}`;
	return withLeadingSlash.endsWith('/') ? withLeadingSlash : `${withLeadingSlash}/`;
}
---

<div class="search-with-switch">
	<nav class="section-switch" aria-label={labels.sectionSwitch}>
		<a href={libraryHref} class:list={['section-link', !isBlogActive && 'is-active']}>
			{labels.docs}
		</a>
		<a href={blogHref} class:list={['section-link', isBlogActive && 'is-active']}>
			{labels.blog}
		</a>
	</nav>
	<div class="search-box">
		<DefaultSearch />
	</div>
</div>

<style>
	.search-with-switch {
		align-items: center;
		display: flex;
		gap: 0.65rem;
		width: min(100%, 38rem);
	}

	.search-box {
		flex: 1 1 auto;
		min-width: 0;
	}

	.section-switch {
		align-items: center;
		background-color: var(--sl-color-bg-nav);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 999px;
		display: flex;
		flex: 0 0 auto;
		gap: 0.2rem;
		padding: 0.2rem;
	}

	.section-link {
		border-radius: 999px;
		color: var(--sl-color-text);
		font-size: 0.76rem;
		font-weight: 600;
		line-height: 1;
		padding: 0.42rem 0.7rem;
		text-decoration: none;
		transition: background-color 0.2s ease, color 0.2s ease;
		white-space: nowrap;
	}

	.section-link:hover {
		color: var(--sl-color-text-accent);
	}

	.section-switch .section-link.is-active,
	.section-switch .section-link.is-active:link,
	.section-switch .section-link.is-active:visited,
	.section-switch .section-link.is-active:hover,
	.section-switch .section-link.is-active:focus-visible {
		background-color: var(--sl-color-accent);
		color: #fff !important;
	}

	@media (max-width: 50rem) {
		.search-with-switch {
			gap: 0.5rem;
			width: 100%;
		}

		.section-link {
			font-size: 0.72rem;
			padding: 0.38rem 0.62rem;
		}
	}
</style>
