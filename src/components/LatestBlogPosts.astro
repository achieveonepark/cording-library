---
import { getCollection } from 'astro:content';
import blogConfig from 'virtual:starlight-blog-config';

const maxPosts = 5;
const safePrefix = trimSlashes(blogConfig.prefix || 'blog');
const blogPrefix = `${safePrefix}/`;

const posts = (await getCollection('docs'))
	.filter((entry) => entry.id.startsWith(blogPrefix) && entry.id !== `${blogPrefix}index`)
	.filter((entry) => entry.data.draft !== true)
	.sort((first, second) => getEntryDate(second) - getEntryDate(first))
	.slice(0, maxPosts);

function trimSlashes(value) {
	return value.replace(/^\/+|\/+$/g, '');
}

function getEntryDate(entry) {
	return entry.data.date instanceof Date ? entry.data.date.getTime() : 0;
}

function formatDate(value) {
	if (!(value instanceof Date)) return '';
	return new Intl.DateTimeFormat('ko-KR', {
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
	}).format(value);
}
---

<section class="latest-blog" aria-labelledby="latest-blog-title">
	<div class="latest-blog-header">
		<h2 id="latest-blog-title">Latest Blog</h2>
		<a href={`/${safePrefix}/`} class="view-all">View all posts</a>
	</div>
	{posts.length === 0 ? (
		<p class="empty-message">No blog posts yet.</p>
	) : (
		<ul class="latest-blog-list">
			{posts.map((post) => (
				<li class="latest-blog-item">
					<a href={`/${post.id}/`} class="post-link">{post.data.title}</a>
					{post.data.date instanceof Date && (
						<time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
					)}
				</li>
			))}
		</ul>
	)}
</section>

<style>
	.latest-blog {
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.85rem;
		margin: 0 0 1.75rem;
		padding: 1rem 1rem 0.8rem;
	}

	.latest-blog-header {
		align-items: baseline;
		display: flex;
		gap: 0.65rem;
		justify-content: space-between;
		margin-bottom: 0.7rem;
	}

	.latest-blog-header h2 {
		font-size: 1.02rem;
		margin: 0;
	}

	.view-all {
		font-size: 0.85rem;
		font-weight: 600;
		text-decoration: none;
	}

	.latest-blog-list {
		display: grid;
		gap: 0.55rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.latest-blog-item {
		align-items: baseline;
		display: flex;
		gap: 0.55rem;
		justify-content: space-between;
	}

	.post-link {
		font-weight: 600;
		line-height: 1.3;
		text-decoration: none;
	}

	.latest-blog-item time {
		color: var(--sl-color-gray-2);
		font-size: 0.8rem;
		white-space: nowrap;
	}

	.empty-message {
		color: var(--sl-color-gray-2);
		margin: 0;
	}

	@media (max-width: 50rem) {
		.latest-blog-item {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.15rem;
		}
	}
</style>
