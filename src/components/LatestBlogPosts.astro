---
import { getCollection } from 'astro:content';
import starlightConfig from 'virtual:starlight/user-config';
import blogConfig from 'virtual:starlight-blog-config';

const maxPosts = 5;
const safePrefix = trimSlashes(blogConfig.prefix || 'blog');
const routeLocale = Astro.locals.starlightRoute.locale;
const routeLang = Astro.locals.starlightRoute.lang || 'ko';
const defaultLocale =
	starlightConfig.defaultLocale.locale === 'root' ? undefined : starlightConfig.defaultLocale.locale;
const defaultBlogPrefix = withLocale(safePrefix, defaultLocale);

const labelsByLocale = {
	root: {
		heading: '최근 글',
		viewAll: '전체 글 보기',
		empty: '아직 게시글이 없습니다.',
	},
	en: {
		heading: 'Latest Posts',
		viewAll: 'View all posts',
		empty: 'No blog posts yet.',
	},
	ja: {
		heading: '最新記事',
		viewAll: 'すべての記事を見る',
		empty: 'まだ記事がありません。',
	},
};

const activeLocale = routeLocale ?? 'root';
const labels = labelsByLocale[activeLocale] ?? labelsByLocale.root;
const blogHref = toPageHref(withLocale(safePrefix, routeLocale));

const posts = (await getLocalizedBlogEntries(routeLocale))
	.sort((first, second) => getEntryDate(second) - getEntryDate(first))
	.slice(0, maxPosts);

async function getLocalizedBlogEntries(locale) {
	const entries = await getCollection('docs');
	const defaultEntries = entries.filter(
		(entry) => entry.id.startsWith(`${defaultBlogPrefix}/`) && entry.id !== `${defaultBlogPrefix}/index`
	);

	if (locale === defaultLocale) return defaultEntries;

	return defaultEntries.map((entry) => {
		const translatedEntryId = withLocale(entry.id, locale);
		return entries.find((candidate) => candidate.id === translatedEntryId) ?? entry;
	});
}

function withLocale(path, locale) {
	const currentLocale = getLocaleFromPath(path);
	if (currentLocale === locale) return path;
	if (currentLocale) {
		return path.replace(`${currentLocale}/`, locale ? `${locale}/` : '');
	}
	return locale ? `${locale}/${path}` : path;
}

function getLocaleFromPath(path) {
	const baseSegment = path.split('/')[0];
	return starlightConfig.locales && baseSegment && baseSegment in starlightConfig.locales
		? baseSegment
		: undefined;
}

function toPageHref(path) {
	return `/${trimSlashes(path)}/`;
}

function trimSlashes(value) {
	return value.replace(/^\/+|\/+$/g, '');
}

function getEntryDate(entry) {
	return entry.data.date instanceof Date ? entry.data.date.getTime() : 0;
}

function formatDate(value) {
	if (!(value instanceof Date)) return '';
	return new Intl.DateTimeFormat(routeLang, {
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
	}).format(value);
}
---

<section class="latest-blog" aria-labelledby="latest-blog-title">
	<div class="latest-blog-header">
		<h2 id="latest-blog-title">{labels.heading}</h2>
		<a href={blogHref} class="view-all">{labels.viewAll}</a>
	</div>
	{posts.length === 0 ? (
		<p class="empty-message">{labels.empty}</p>
	) : (
		<ul class="latest-blog-list">
			{posts.map((post) => (
				<li class="latest-blog-item">
					<a href={toPageHref(withLocale(post.id, routeLocale))} class="post-link">{post.data.title}</a>
					{post.data.date instanceof Date && (
						<time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
					)}
				</li>
			))}
		</ul>
	)}
</section>

<style>
	.latest-blog {
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.85rem;
		margin: 0 0 1.75rem;
		padding: 1rem 1rem 0.8rem;
	}

	.latest-blog-header {
		align-items: baseline;
		display: flex;
		gap: 0.65rem;
		justify-content: space-between;
		margin-bottom: 0.7rem;
	}

	.latest-blog-header h2 {
		font-size: 1.02rem;
		margin: 0;
	}

	.view-all {
		font-size: 0.85rem;
		font-weight: 600;
		text-decoration: none;
	}

	.latest-blog-list {
		display: grid;
		gap: 0.55rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.latest-blog-item {
		align-items: baseline;
		display: flex;
		gap: 0.55rem;
		justify-content: space-between;
	}

	.post-link {
		font-weight: 600;
		line-height: 1.3;
		text-decoration: none;
	}

	.latest-blog-item time {
		color: var(--sl-color-gray-2);
		font-size: 0.8rem;
		white-space: nowrap;
	}

	.empty-message {
		color: var(--sl-color-gray-2);
		margin: 0;
	}

	@media (max-width: 50rem) {
		.latest-blog-item {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.15rem;
		}
	}
</style>
